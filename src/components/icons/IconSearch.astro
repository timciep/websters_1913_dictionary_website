---
interface Props {
  class?: string;
  width?: number;
  height?: number;
}
const { class: className, width = 18, height = 18 } = Astro.props;
---
<svg class={className} xmlns="http://www.w3.org/2000/svg" width={width} height={height} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="23" y1="23" x2="16.65" y2="16.65"/></svg>
