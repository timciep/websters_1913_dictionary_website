---
import type { EntryPage } from '../lib/entry';
import { renderDefinition } from '../lib/crossref';
import { expandPos } from '../lib/pos';
import { formatAuthor } from '../lib/authors';

interface Props {
  page: EntryPage;
  knownSlugs: Set<string>;
}
const { page, knownSlugs } = Astro.props;
---
<article class="entry">
  <div class="entry-header">
    <h2 class="headword">{page.headword}</h2>
    <button type="button" class="share" data-share aria-label={`Copy link to ${page.headword}`}>
      <span class="share-label">Copy link</span>
    </button>
  </div>

  {page.forms.map((form, idx) => (
    <section class="form" data-form-index={idx}>
      <p class="lead">
        <span class="lead-hw">{form.headword}</span>
        {form.pronunciation && <span class="lead-pron"> {form.pronunciation}</span>}
        {form.partOfSpeech && (
          <span class="lead-pos">, {
            expandPos(form.partOfSpeech)
              ? <abbr class="pos-abbr" tabindex="0" data-expand={expandPos(form.partOfSpeech)!}>{form.partOfSpeech}</abbr>
              : form.partOfSpeech
          }</span>
        )}
      </p>
      {form.etymology && <p class="ety" set:html={renderDefinition(form.etymology, knownSlugs)} />}

      {form.senses.map((sense) => (
        <div class="sense">
          <div class="num">{sense.number ?? ''}</div>
          <div class="body">
            <Fragment set:html={renderDefinition(sense.definition, knownSlugs)} />
            {sense.quotations.map((q) => (
              <div class="quote">
                <span>{q.text}</span>
                {q.author && <span class="author">— {formatAuthor(q.author)}</span>}
              </div>
            ))}
          </div>
        </div>
      ))}

      {form.variants.length > 0 && (
        <p class="variants">Also: {form.variants.join(', ')}</p>
      )}
    </section>
  ))}
</article>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-share]').forEach((btn) => {
    const label = btn.querySelector<HTMLElement>('.share-label');
    if (!label) return;
    const original = label.textContent ?? 'Copy link';
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        label.textContent = 'Copied';
        btn.classList.add('copied');
      } catch {
        label.textContent = 'Press ⌘C';
      }
      window.setTimeout(() => {
        label.textContent = original;
        btn.classList.remove('copied');
      }, 1500);
    });
  });
</script>
