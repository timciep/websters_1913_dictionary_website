---
// Vanilla client-side search island. Loads /search-index.json on first focus,
// builds a MiniSearch index, and shows autocomplete results.
import IconSearch from './icons/IconSearch.astro';
---
<div class="search">
  <div class="search-input-wrap">
    <IconSearch class="search-icon" />
    <input
      id="q"
      type="search"
      autocomplete="off"
      placeholder="Search the dictionary…"
      aria-label="Search the dictionary"
    />
  </div>
  <ul id="results" class="results" hidden></ul>
</div>
<div id="word-popover" class="word-popover" role="dialog" aria-label="Look up selected word" hidden>
  <a id="word-popover-link" href="#"></a>
</div>

<script>
  import MiniSearch from 'minisearch';
  import posthog from 'posthog-js';
  import { slugify } from '../lib/slug';

  interface Row { s: string; h: string; p?: string; d?: string }

  const input = document.getElementById('q') as HTMLInputElement;
  const list = document.getElementById('results') as HTMLUListElement;
  const popover = document.getElementById('word-popover') as HTMLDivElement;
  const popoverLink = document.getElementById('word-popover-link') as HTMLAnchorElement;
  let mini: MiniSearch<Row> | null = null;
  let rows: Row[] = [];
  let slugMap: Map<string, Row> | null = null;
  let selected = -1;
  let lastHits: Row[] = [];
  let lastQuery = '';
  let performedTimer: number | null = null;
  let performedQuery = '';

  function capture(event: string, props: Record<string, unknown>) {
    if (import.meta.env.PROD) posthog.capture(`dictionary_${event}`, props);
  }

  async function ensureLoaded() {
    if (mini) return;
    const res = await fetch('/search-index.json');
    rows = (await res.json()) as Row[];
    slugMap = new Map(rows.map((r) => [r.s, r]));
    mini = new MiniSearch<Row>({
      idField: 's',
      fields: ['h'],
      storeFields: ['s', 'h', 'p', 'd'],
      searchOptions: {
        prefix: true,
        fuzzy: 0.15,
        boost: { h: 2 },
        // MiniSearch defaults rank fuzzy (0.45) above prefix (0.375), so a 1-edit
        // fuzzy match beats a 1-char prefix extension — "gende" surfaces "genie"
        // ahead of "gender". Bias toward prefix; keep fuzzy as a typo fallback.
        weights: { prefix: 1, fuzzy: 0.1 },
      },
    });
    mini.addAll(rows);
  }

  function render(items: Row[]) {
    if (items.length === 0) {
      list.hidden = true;
      list.innerHTML = '';
      selected = -1;
      return;
    }
    list.hidden = false;
    list.innerHTML = items
      .slice(0, 10)
      .map((r, i) => {
        const pos = r.p ? `<span class="hit-pos">${escape(r.p)}</span>` : '';
        return `<li role="option" data-slug="${r.s}" data-i="${i}">
          <span class="hit-hw">${escape(r.h)}</span>${pos}
        </li>`;
      })
      .join('');
    selected = -1;
  }

  function escape(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function go(slug: string, method: 'click' | 'enter', position: number) {
    capture('search_result_selected', {
      query: lastQuery,
      slug,
      position,
      method,
      result_count: lastHits.length,
    });
    window.location.href = `/word/${slug}/`;
  }

  input.addEventListener('focus', () => { void ensureLoaded(); });

  // On touch devices, pin the search bar to the top of the viewport on the
  // first keystroke per focus — by then iOS's keyboard-up animation has
  // settled, so we don't race its automatic focus-scroll.
  let pinnedThisFocus = false;
  input.addEventListener('blur', () => { pinnedThisFocus = false; });

  input.addEventListener('input', async () => {
    if (!pinnedThisFocus && matchMedia('(hover: none)').matches) {
      pinnedThisFocus = true;
      input.closest('.search')?.scrollIntoView({ block: 'start' });
    }
    await ensureLoaded();
    const q = input.value.trim();
    lastQuery = q;
    if (!q || !mini) { lastHits = []; render([]); return; }
    const hits = mini.search(q) as unknown as Row[];
    // Promote an exact-headword match to position 1. BM25 deflates the IDF of
    // common terms ("word" appears as a token in dozens of compound headwords —
    // Word-blind, Word-catcher, …) so prefix matches against rarer terms like
    // "wordy" can outscore the literal "Word" entry. Bypass that by trusting
    // the slug.
    const exactSlug = slugify(q);
    if (exactSlug && slugMap?.has(exactSlug)) {
      const idx = hits.findIndex((r) => r.s === exactSlug);
      if (idx > 0) {
        const [exact] = hits.splice(idx, 1);
        hits.unshift(exact);
      } else if (idx < 0) {
        hits.unshift(slugMap.get(exactSlug)!);
      }
    }
    lastHits = hits;
    render(hits);
    schedulePerformed(q, hits.length);
  });

  function schedulePerformed(q: string, count: number) {
    if (performedTimer !== null) window.clearTimeout(performedTimer);
    performedTimer = window.setTimeout(() => {
      if (q === performedQuery) return;
      performedQuery = q;
      capture('search_performed', {
        query: q,
        query_length: q.length,
        result_count: count,
        has_results: count > 0,
      });
    }, 600);
  }

  input.addEventListener('keydown', (e) => {
    const items = list.querySelectorAll('li');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selected = Math.min(items.length - 1, selected + 1);
      updateSelection(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selected = Math.max(-1, selected - 1);
      updateSelection(items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const index = selected >= 0 ? selected : 0;
      const target = items[index];
      const slug = target?.getAttribute('data-slug');
      if (slug) go(slug, 'enter', index);
    } else if (e.key === 'Escape') {
      render([]);
      input.blur();
    }
  });

  function updateSelection(items: NodeListOf<Element>) {
    items.forEach((el, i) => {
      el.setAttribute('aria-selected', i === selected ? 'true' : 'false');
    });
  }

  function navigateFromResult(e: Event) {
    const li = (e.target as HTMLElement).closest('li');
    if (!li) return;
    const slug = li.getAttribute('data-slug');
    const index = Number(li.getAttribute('data-i') ?? '0');
    if (!slug) return;
    e.preventDefault();
    go(slug, 'click', index);
  }
  // Prevent taps on results from blurring the input — this stops the mobile
  // keyboard from dismissing (and reflowing the page) before `click` fires.
  list.addEventListener('mousedown', (e) => { e.preventDefault(); });
  list.addEventListener('click', navigateFromResult);

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.search')) render([]);
  });

  // --- Word-selection lookup ------------------------------------------------
  // Double-click (desktop) or long-press (mobile) selects a word; we detect
  // that selection, check if it matches a headword, and offer a link to it.

  const WORD_RE = /^[\p{L}\p{M}'’\-]+$/u;

  function hidePopover() {
    popover.hidden = true;
  }

  function positionPopover(rect: DOMRect) {
    // Absolute positioning in document coordinates. On touch devices we
    // anchor *below* the selection so we don't fight with the native
    // long-press callout (Copy / Look Up / Share), which sits above.
    const isTouch = matchMedia('(hover: none)').matches;
    const gap = 10;
    const top = isTouch
      ? rect.bottom + window.scrollY + gap
      : rect.top + window.scrollY - popover.offsetHeight - gap;
    const centerX = rect.left + window.scrollX + rect.width / 2;
    const halfW = popover.offsetWidth / 2;
    const pad = 8;
    const maxX = document.documentElement.clientWidth + window.scrollX - halfW - pad;
    const minX = window.scrollX + halfW + pad;
    const left = Math.max(minX, Math.min(maxX, centerX)) - halfW;
    popover.style.top = `${Math.max(window.scrollY + pad, top)}px`;
    popover.style.left = `${left}px`;
  }

  async function handleSelectionMaybe() {
    const sel = window.getSelection();
    if (!sel || sel.isCollapsed || sel.rangeCount === 0) { hidePopover(); return; }
    const text = sel.toString().trim();
    if (!text || text.length > 40 || !WORD_RE.test(text)) { hidePopover(); return; }

    // Ignore selections inside our own UI.
    const anchor = sel.anchorNode;
    const anchorEl = anchor instanceof Element ? anchor : anchor?.parentElement ?? null;
    if (anchorEl?.closest('.search, .word-popover')) { hidePopover(); return; }

    await ensureLoaded();
    if (!slugMap) { hidePopover(); return; }

    const slug = slugify(text);
    const hit = slug ? slugMap.get(slug) : null;
    if (!hit) { hidePopover(); return; }

    popoverLink.textContent = `Look up “${hit.h}”`;
    popoverLink.href = `/word/${hit.s}/`;
    popover.hidden = false;
    // Needs to be visible before we can measure it.
    const rect = sel.getRangeAt(0).getBoundingClientRect();
    if (rect.width === 0 && rect.height === 0) { hidePopover(); return; }
    positionPopover(rect);
  }

  // --- Mouse long-press to select a word -----------------------------------
  // On devices with a pointer, press-and-hold on a word for ~500ms to select
  // it (mirrors the mobile long-press affordance).

  const LONG_PRESS_MS = 500;
  const LONG_PRESS_TOLERANCE_PX = 6;
  let pressTimer: number | null = null;
  let pressStart: { x: number; y: number } | null = null;
  let longPressFired = false;

  function cancelLongPress() {
    if (pressTimer !== null) { window.clearTimeout(pressTimer); pressTimer = null; }
    pressStart = null;
  }

  function selectWordAtPoint(x: number, y: number): boolean {
    let node: Node | null = null;
    let offset = 0;
    const docAny = document as Document & {
      caretPositionFromPoint?: (x: number, y: number) => { offsetNode: Node; offset: number } | null;
    };
    if (typeof document.caretRangeFromPoint === 'function') {
      const r = document.caretRangeFromPoint(x, y);
      if (!r) return false;
      node = r.startContainer;
      offset = r.startOffset;
    } else if (typeof docAny.caretPositionFromPoint === 'function') {
      const p = docAny.caretPositionFromPoint(x, y);
      if (!p) return false;
      node = p.offsetNode;
      offset = p.offset;
    } else {
      return false;
    }
    if (!node || node.nodeType !== Node.TEXT_NODE) return false;
    const text = (node as Text).data;
    const wordChar = /[\p{L}\p{M}'’\-]/u;
    let start = offset;
    let end = offset;
    while (start > 0 && wordChar.test(text.charAt(start - 1))) start--;
    while (end < text.length && wordChar.test(text.charAt(end))) end++;
    if (start === end) return false;
    const range = document.createRange();
    range.setStart(node, start);
    range.setEnd(node, end);
    const sel = window.getSelection();
    if (!sel) return false;
    sel.removeAllRanges();
    sel.addRange(range);
    return true;
  }

  document.addEventListener('mousedown', (e) => {
    if (e.button !== 0) return;
    // Only on non-touch pointers.
    if (!matchMedia('(hover: hover)').matches) return;
    const t = e.target as HTMLElement | null;
    if (!t) return;
    // Skip interactive / UI regions where long-press shouldn't hijack input.
    if (t.closest('a, button, input, textarea, select, label, .search, .word-popover')) return;
    longPressFired = false;
    pressStart = { x: e.clientX, y: e.clientY };
    if (pressTimer !== null) window.clearTimeout(pressTimer);
    pressTimer = window.setTimeout(() => {
      pressTimer = null;
      if (!pressStart) return;
      const { x, y } = pressStart;
      pressStart = null;
      if (selectWordAtPoint(x, y)) {
        longPressFired = true;
        // Run the popover check immediately so feedback is instant.
        void handleSelectionMaybe();
      }
    }, LONG_PRESS_MS);
  });

  document.addEventListener('mousemove', (e) => {
    if (!pressStart) return;
    const dx = e.clientX - pressStart.x;
    const dy = e.clientY - pressStart.y;
    if (dx * dx + dy * dy > LONG_PRESS_TOLERANCE_PX * LONG_PRESS_TOLERANCE_PX) cancelLongPress();
  });

  document.addEventListener('mouseup', () => { cancelLongPress(); });
  document.addEventListener('mouseleave', () => { cancelLongPress(); });
  // If a long-press just fired, suppress the following click so we don't
  // navigate away from an enclosing link the user pressed on.
  document.addEventListener('click', (e) => {
    if (longPressFired) {
      longPressFired = false;
      e.preventDefault();
      e.stopPropagation();
    }
  }, true);

  // Debounced selection watcher — fires after the selection settles. Covers
  // desktop double-click, desktop drag-select, desktop long-press, and mobile
  // long-press uniformly.
  let selectionTimer: number | null = null;
  function scheduleSelectionCheck(delay: number) {
    if (selectionTimer !== null) window.clearTimeout(selectionTimer);
    selectionTimer = window.setTimeout(() => {
      selectionTimer = null;
      void handleSelectionMaybe();
    }, delay);
  }
  document.addEventListener('selectionchange', () => {
    const sel = window.getSelection();
    if (!sel || sel.isCollapsed) {
      if (selectionTimer !== null) { window.clearTimeout(selectionTimer); selectionTimer = null; }
      hidePopover();
      return;
    }
    // Debounce so we don't thrash during drag-selects or long-press settling.
    scheduleSelectionCheck(180);
  });
  // Touch release is a strong "selection is now final" signal on mobile; run
  // immediately on top of the debounce so the popover appears promptly after
  // long-press.
  document.addEventListener('touchend', () => scheduleSelectionCheck(0));

  // On mobile, tapping the link can collapse the selection, which would
  // hide the popover via `selectionchange` before `click` fires. Navigate
  // on pointerdown/touchstart to guarantee it takes effect.
  function navigateFromPopover(e: Event) {
    const href = popoverLink.getAttribute('href');
    if (!href || href === '#') return;
    e.preventDefault();
    capture('word_selection_lookup', { headword: popoverLink.textContent, href });
    window.location.href = href;
  }
  popoverLink.addEventListener('touchstart', navigateFromPopover, { passive: false });
  popoverLink.addEventListener('click', navigateFromPopover);
  window.addEventListener('scroll', hidePopover, { passive: true });
  window.addEventListener('resize', hidePopover);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !popover.hidden) {
      hidePopover();
      return;
    }
    if (e.key !== '/') return;
    if (e.ctrlKey || e.metaKey || e.altKey) return;
    const target = e.target as HTMLElement | null;
    if (target === input) return;
    const tag = target?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
    if (target?.isContentEditable) return;
    e.preventDefault();
    input.focus();
    input.select();
  });
</script>
