---
import Base from '../layouts/Base.astro';
import { loadAllEntries } from '../lib/entry';

const pages = await loadAllEntries();
const formTotal = pages.reduce((n, p) => n + p.forms.length, 0);
const count = formTotal.toLocaleString('en-US');
---
<Base title="Webster's 1913 Dictionary">
  <p style="font-size:1.1rem;line-height:1.6">
    A complete, browsable copy of <em>Webster's Revised Unabridged Dictionary</em>
    of 1913 — {count} headwords.
  </p>
  <p style="color:var(--ink-soft);font-size:0.9rem">
    Type in the search box above; use ↑ ↓ to navigate, Enter to open, Esc to dismiss.
  </p>
</Base>
